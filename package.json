{
  "name": "animastage-lite",
  "description": "AnimaStage Lite — browser MMD studio (WebMMD): VMD, Bullet physics, RTX Lite FX, MP4/Shorts export.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "sync:android:assets": "powershell -ExecutionPolicy Bypass -File scripts/sync-android-assets.ps1",
    "build:android:release": "npm run sync:android:assets && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@google/genai": "^2.4.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mmd-parser": "^1.0.4",
    "motion": "^12.23.24",
    "mp4-muxer": "^5.2.2",
    "postprocessing": "^6.39.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "vite": "^6.2.3",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}

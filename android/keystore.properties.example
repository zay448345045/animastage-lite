# Copy to android/keystore.properties and fill in real values.
# NEVER commit keystore.properties or *.keystore to git.
#
# Create keystore (one time):
#   keytool -genkey -v -keystore E:/keys/webmmd-release.keystore -alias webmmd -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=E:/keys/webmmd-release.keystore
storePassword=CHANGE_ME
keyAlias=webmmd
keyPassword=CHANGE_ME
